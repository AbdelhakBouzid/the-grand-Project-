generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  teacher
  institution_admin
  reviewer
  moderator
  super_admin
}

enum AccountStatus {
  pending
  approved
  rejected
  suspended
  banned
}

enum VerificationStatus {
  pending
  approved
  rejected
  more_info_required
}

enum ReviewAction {
  approve
  reject
  request_more_info
}

enum NotificationType {
  system
  verification
  moderation
}

enum AuditAction {
  verification_reviewed
  role_changed
  user_status_changed
  moderation_action
}

enum InstitutionRequestStatus {
  pending
  approved
  rejected
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String
  role           UserRole       @default(student)
  status         AccountStatus  @default(pending)
  institutionId  String?
  languageCode   String         @default("en")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastLoginAt    DateTime?

  profile               UserProfile?
  institution           Institution?        @relation(fields: [institutionId], references: [id])
  verificationRequests  VerificationRequest[]
  posts                 Post[]
  comments              Comment[]
  reactions             Reaction[]
  groupMemberships      GroupMember[]
  resources             Resource[]
  reports               Report[]            @relation("Reporter")
  adminNotes            AdminNote[]
  notifications         Notification[]
  reviewedRequests      VerificationRequest[] @relation("RequestReviewer")
  auditLogs             AuditLog[]
  institutionRequests      InstitutionRequest[] @relation("InstitutionRequestRequester")
  reviewedInstitutionRequests InstitutionRequest[] @relation("InstitutionRequestReviewer")
}

model UserProfile {
  id          String @id @default(uuid())
  userId      String @unique
  firstName   String
  lastName    String
  displayName String?
  bio         String?
  countryCode String?
  avatarUrl   String?
  user        User   @relation(fields: [userId], references: [id])
}

model Institution {
  id            String   @id @default(uuid())
  name          String
  countryCode   String
  city          String?
  isPublic      Boolean
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())

  aliases       InstitutionAlias[]
  users         User[]
  departments   Department[]
  verificationRequests VerificationRequest[]
  institutionRequests InstitutionRequest[]
}

model InstitutionRequest {
  id               String                   @id @default(uuid())
  requesterUserId  String
  name             String
  countryCode      String
  city             String?
  isPublic         Boolean
  status           InstitutionRequestStatus @default(pending)
  reviewedByUserId String?
  reviewedAt       DateTime?
  rejectionReason  String?
  institutionId    String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  requester        User                     @relation("InstitutionRequestRequester", fields: [requesterUserId], references: [id])
  reviewer         User?                    @relation("InstitutionRequestReviewer", fields: [reviewedByUserId], references: [id])
  institution      Institution?             @relation(fields: [institutionId], references: [id])
}

model InstitutionAlias {
  id            String @id @default(uuid())
  institutionId String
  alias         String
  institution   Institution @relation(fields: [institutionId], references: [id])
}

model EducationLevel {
  id          String @id @default(uuid())
  name        String @unique
  gradeLevels GradeLevel[]
}

model GradeLevel {
  id               String @id @default(uuid())
  educationLevelId String
  name             String
  educationLevel   EducationLevel @relation(fields: [educationLevelId], references: [id])
}

model Department {
  id            String @id @default(uuid())
  institutionId String
  name          String
  institution   Institution @relation(fields: [institutionId], references: [id])
}

model VerificationRequest {
  id              String @id @default(uuid())
  userId          String
  institutionId   String
  status          VerificationStatus @default(pending)
  note            String?
  reviewerId      String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])
  institution     Institution @relation(fields: [institutionId], references: [id])
  reviewer        User? @relation("RequestReviewer", fields: [reviewerId], references: [id])
  documents       VerificationDocument[]
}

model VerificationDocument {
  id                    String @id @default(uuid())
  verificationRequestId String
  originalFilename      String
  mimeType              String
  sizeBytes             Int
  storageKey            String
  checksumSha256        String
  createdAt             DateTime @default(now())

  verificationRequest   VerificationRequest @relation(fields: [verificationRequestId], references: [id])
  accessLogs            DocumentAccessLog[]
}

model DocumentAccessLog {
  id            String @id @default(uuid())
  documentId    String
  actorUserId   String
  action        String
  createdAt     DateTime @default(now())
  document      VerificationDocument @relation(fields: [documentId], references: [id])
}

model Post {
  id         String     @id @default(uuid())
  userId     String
  body       String
  createdAt  DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id])
  media      PostMedia[]
  comments   Comment[]
  reactions  Reaction[]
}

model PostMedia {
  id         String   @id @default(uuid())
  postId     String
  url        String
  mimeType   String

  post       Post     @relation(fields: [postId], references: [id])
}

model Comment {
  id         String   @id @default(uuid())
  postId     String
  userId     String
  body       String
  createdAt  DateTime @default(now())

  post       Post     @relation(fields: [postId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Reaction {
  id         String   @id @default(uuid())
  postId     String
  userId     String
  type       String

  post       Post     @relation(fields: [postId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId, type])
}

model Group {
  id         String       @id @default(uuid())
  name       String
  description String?
  isPrivate  Boolean      @default(false)

  members    GroupMember[]
}

model GroupMember {
  id         String   @id @default(uuid())
  groupId    String
  userId     String
  role       String
  joinedAt   DateTime @default(now())

  group      Group    @relation(fields: [groupId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model Resource {
  id          String        @id @default(uuid())
  title       String
  description String?
  ownerUserId String

  owner       User          @relation(fields: [ownerUserId], references: [id])
  files       ResourceFile[]
}

model ResourceFile {
  id          String   @id @default(uuid())
  resourceId  String
  fileUrl     String

  resource    Resource @relation(fields: [resourceId], references: [id])
}

model ExamSet {
  id          String   @id @default(uuid())
  title       String
  subject     String
  year        Int
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  targetType  String
  targetId    String
  reason      String
  createdAt   DateTime @default(now())

  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
}

model ModerationAction {
  id          String   @id @default(uuid())
  targetType  String
  targetId    String
  action      ReviewAction
  reason      String?
  createdAt   DateTime @default(now())
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id])
}

model AdminNote {
  id          String   @id @default(uuid())
  userId      String
  authorId    String
  note        String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String    @id @default(uuid())
  actorUserId String
  action      AuditAction
  targetType  String
  targetId    String
  meta        Json?
  createdAt   DateTime  @default(now())

  actor       User      @relation(fields: [actorUserId], references: [id])
}

model Language {
  code        String   @id
  name        String
  isRtl       Boolean  @default(false)
}
